# .env.example - Configuration for Bollinger Band Reversal Bot
# Copy this to .env and fill in your values

# Exchange API Credentials
SHARKEX_API_KEY=your_api_key_here
SHARKEX_API_SECRET=your_api_secret_here
EXCHANGE_NAME=sharkex
SYMBOL=BTC/USDT

# Strategy Parameters
BB_PERIOD=20
BB_STDDEV=2.0
NEAR_THRESHOLD=0.002
TRAIL_PCT=0.005
SHORT_ENABLED=false
TRAILING_STOP_ENABLED=false
CANDLES_WINDOW=50

# Risk Management
TRADE_SIZE_INR=20000
USD_INR_RATE=83.5
MAX_DAILY_LOSS_INR=3000
MAX_TRADES_PER_DAY=30

# Bot Settings
POLL_INTERVAL=60
PAPER_TRADING=false