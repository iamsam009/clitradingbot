# .env.example - Configuration for Bollinger Squeeze Breakout Bot
# Copy this to .env and fill in your values

# Exchange API Credentials
SHARKEX_API_KEY=your_api_key_here
SHARKEX_API_SECRET=your_api_secret_here
EXCHANGE_NAME=sharkex
SYMBOL=BTC/USDT
CONTRACT_NAME=BTCUSDT

# Leverage (1 = spot, no leverage)
LEVERAGE=1

# Strategy Parameters (15-min Bollinger Squeeze Breakout)
BB_PERIOD=20
BB_STDDEV=2.0
CANDLE_TF=15m
DATA_WINDOW=120
DISPLAY_WINDOW=40
SQUEEZE_LOOKBACK=10
BREAKOUT_LOOKBACK=10
TRAILING_LOOKBACK=5
LIMIT_ORDER_TIMEOUT=10
SHORT_ENABLED=false

# Risk Management
TRADE_SIZE_INR=20000
USD_INR_RATE=83.5
MAX_DAILY_LOSS_INR=3000
MAX_TRADES_PER_DAY=30

# Bot Settings
POLL_INTERVAL=5